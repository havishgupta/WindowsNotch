<Window x:Class="DynamicNotch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notch" Height="8" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        Loaded="Window_Loaded" Deactivated="Window_Deactivated"
        MouseEnter="Window_MouseEnter" MouseLeave="Window_MouseLeave"
        AllowDrop="True" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave" Drop="Window_Drop">
    
    <Grid Background="Transparent">
        <!-- 50% transparency for black background (#80000000) -->
        <Border Name="NotchBorder" Background="#01000000" CornerRadius="0,0,15,15" 
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Width="600" Height="8" Margin="0">
            
            <StackPanel Name="NotchContent" Margin="15" Visibility="Collapsed">
                <!-- Tools -->
                <StackPanel Name="ToolsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="&#xE722;" FontFamily="Segoe Fluent Icons" ToolTip="Snipping Tool (Screenshot)" Click="Snip_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Margin="0,0,20,0" Cursor="Hand" />
                    <Button Content="&#xE77F;" FontFamily="Segoe Fluent Icons" ToolTip="Clipboard History" Click="Clip_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Margin="0,0,20,0" Cursor="Hand" />
                    <Button Content="&#xE11D;" FontFamily="Segoe Fluent Icons" ToolTip="Emoji Bar" Click="Emoji_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="20" Margin="0,0,20,0" Cursor="Hand" />
                    <Button Content="&#xE74D;" FontFamily="Segoe Fluent Icons" ToolTip="Clear Shelf" Click="ClearFiles_Click" Background="Transparent" Foreground="#FF5555" BorderThickness="0" FontSize="20" Margin="20,0,0,0" Cursor="Hand" />
                    <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" ToolTip="Close Notch" Click="Close_Click" Background="Transparent" Foreground="#FF4444" BorderThickness="0" FontSize="14" Margin="20,0,0,0" Cursor="Hand" />
                </StackPanel>

                <!-- Files Drop Area / List -->
                <TextBlock Name="EmptyText" Text="Drop files or folders here" Foreground="#DDDDDD" HorizontalAlignment="Center" Margin="0,15,0,15" FontSize="14"/>
                
                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="FilesList" ItemsSource="{Binding StoredFiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" MaxWidth="550"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#44FFFFFF" CornerRadius="8" Margin="5" Padding="10,6"
                                        MouseLeftButtonDown="FileItem_MouseLeftButtonDown"
                                        MouseMove="FileItem_MouseMove"
                                        Cursor="Hand" ToolTip="Drag out to move/copy">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding IconSymbol}" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="13" MaxWidth="150" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" ToolTip="Remove from shelf" Tag="{Binding}" Click="RemoveFile_Click" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Margin="8,0,0,0" Padding="0" FontSize="10" VerticalAlignment="Center" Cursor="Hand"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>